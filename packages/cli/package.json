{
  "name": "@quizz/cli",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "bin": {
    "quizz": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch --env-file=../../.env src/index.ts",
    "start": "tsx --env-file=../../.env src/index.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src --ext .ts"
  },
  "dependencies": {
    "@quizz/core": "workspace:*",
    "commander": "^14.0.3",
    "ink": "^7.0.2",
    "react": "^19.2.6"
  },
  "devDependencies": {
    "@types/node": "^22.15.21",
    "@types/react": "^19.2.14",
    "tsx": "^4.21.0",
    "typescript": "^5.8.3"
  }
}

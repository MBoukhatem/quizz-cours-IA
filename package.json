{
  "name": "quizz-cours-ia",
  "version": "0.0.1",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "dev": "concurrently \"pnpm --filter @quizz/api dev\" \"pnpm --filter @quizz/web dev\"",
    "build": "pnpm --filter @quizz/core build && pnpm --filter @quizz/api build && pnpm --filter @quizz/cli build && pnpm --filter @quizz/web build",
    "cli": "pnpm --filter @quizz/cli start",
    "lint": "pnpm -r lint",
    "format": "prettier --write \"packages/*/src/**/*.{ts,tsx}\"",
    "typecheck": "pnpm -r typecheck",
    "bootstrap": "tsx scripts/bootstrap-qdrant.ts"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "prettier": "^3.8.3",
    "@typescript-eslint/eslint-plugin": "^8.59.2",
    "@typescript-eslint/parser": "^8.59.2",
    "eslint": "^9.27.0",
    "tsx": "^4.21.0",
    "typescript": "^5.8.3"
  }
}

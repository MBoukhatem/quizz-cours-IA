# =============================================================================
# LLM — Provider OpenAI-compatible (OpenRouter, OpenAI, vLLM local, etc.)
# =============================================================================
# Par défaut : OpenRouter avec un modèle free. Crée ta clé sur
# https://openrouter.ai/keys et choisis un modèle compatible tool_calling.
VLLM_BASE_URL=https://openrouter.ai/api/v1
VLLM_API_KEY=sk-or-v1-replace-me
VLLM_MODEL=google/gemini-2.0-flash-exp:free

# Alternative pour vLLM local (Qwen3.5-35B-A3B sur GPU, port 11435) :
# VLLM_BASE_URL=http://host.docker.internal:11435/v1
# VLLM_API_KEY=any-string
# VLLM_MODEL=qwen35-35b-a3b

# =============================================================================
# Embeddings — Infinity local (bge-m3, gratuit, CPU ou GPU)
# =============================================================================
# Lance le serveur séparément :
#   docker run -d --name infinity -p 11436:7997 michaelf34/infinity:latest \
#     v2 --model-id BAAI/bge-m3 --port 7997
EMBEDDINGS_BASE_URL=http://host.docker.internal:11436
EMBEDDINGS_MODEL=bge-m3
EMBEDDINGS_DIM=1024

# =============================================================================
# Qdrant — interne au réseau Docker, ne pas modifier en mode compose
# =============================================================================
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=quiz_cours

# =============================================================================
# API
# =============================================================================
API_HOST=0.0.0.0
API_PORT=8080
API_RATE_LIMIT_MAX=100
API_RATE_LIMIT_WINDOW=1 minute

# =============================================================================
# Stockage / mémoire / RAG / divers
# =============================================================================
SQLITE_PATH=./data/memory.db

CHUNK_SIZE=800
CHUNK_OVERLAP=120
RETRIEVAL_TOP_K=5

DDG_REGION=fr-fr
LOG_LEVEL=info

# Ollama (LLM local — pas de clé API requise)
# URL du serveur Ollama (docker-compose surcharge à http://ollama:11434)
OLLAMA_BASE_URL=http://ollama:11434

# Modèle par défaut (doit être présent dans OLLAMA_ALLOWED_MODELS)
OLLAMA_MODEL=qwen2.5:0.5b

# Modèles sélectionnables depuis l'UI (du plus léger au plus capable)
OLLAMA_ALLOWED_MODELS=qwen2.5:0.5b,gemma2:2b,llama3.2:3b,qwen2.5:7b

# ChromaDB — hôte et port (docker-compose surcharge CHROMA_HOST=chromadb)
CHROMA_HOST=chromadb
CHROMA_PORT=8000
CHROMA_COLLECTION=courses

# Modèle d'embeddings local (sentence-transformers, aucune clé requise)
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

APP_LOG_LEVEL=INFO
QUIZ_DEFAULT_QUESTIONS=5
MAX_HISTORY_TURNS=5

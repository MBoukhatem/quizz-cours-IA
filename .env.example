# vLLM (Qwen3.5-35B-A3B)
VLLM_BASE_URL=http://host.docker.internal:11435/v1
VLLM_MODEL=qwen35-35b-a3b
VLLM_API_KEY=replace-me

# Embeddings (Infinity / bge-m3)
EMBEDDINGS_BASE_URL=http://host.docker.internal:11436
EMBEDDINGS_MODEL=bge-m3
EMBEDDINGS_DIM=1024

# Qdrant
QDRANT_URL=http://host.docker.internal:6333
QDRANT_COLLECTION=quiz_cours

# API
API_HOST=0.0.0.0
API_PORT=8080
API_RATE_LIMIT_MAX=100
API_RATE_LIMIT_WINDOW=1 minute

# Memory
SQLITE_PATH=./data/memory.db

# RAG
CHUNK_SIZE=800
CHUNK_OVERLAP=120
RETRIEVAL_TOP_K=5

# Web search
DDG_REGION=fr-fr

# Logs
LOG_LEVEL=info

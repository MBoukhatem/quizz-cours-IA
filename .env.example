# OpenRouter API — obligatoire, obtenir sur https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-REPLACE_ME

# Modèle principal (gratuit)
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free

# Modèle de secours si le principal échoue
OPENROUTER_FALLBACK_MODEL=google/gemini-2.0-flash-exp:free

# URL de base de l'API OpenRouter
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ChromaDB — hôte et port (docker-compose surcharge CHROMA_HOST=chromadb)
CHROMA_HOST=chromadb
CHROMA_PORT=8000

# Nom de la collection ChromaDB
CHROMA_COLLECTION=courses

# Modèle d'embeddings local (sentence-transformers, aucune clé requise)
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Niveau de log : DEBUG | INFO | WARNING | ERROR
APP_LOG_LEVEL=INFO

# Nombre de questions par défaut dans un quiz
QUIZ_DEFAULT_QUESTIONS=5

# Nombre maximum de tours de conversation conservés en mémoire
MAX_HISTORY_TURNS=5

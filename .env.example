# Google AI Studio (Gemini) — obligatoire, obtenir sur https://aistudio.google.com/apikey
GEMINI_API_KEY=REPLACE_ME

# Modèle Gemini par défaut (modifiable depuis l'UI au runtime)
GEMINI_MODEL=gemini-2.5-flash-lite

# Liste des modèles Flash sélectionnables (free tier Google AI Studio)
GEMINI_ALLOWED_MODELS=gemini-2.5-flash-lite,gemini-2.5-flash,gemini-2.0-flash-lite,gemini-2.0-flash,gemini-flash-lite-latest

# Base URL Google Generative Language API
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta

# ChromaDB — hôte et port (docker-compose surcharge CHROMA_HOST=chromadb)
CHROMA_HOST=chromadb
CHROMA_PORT=8000
CHROMA_COLLECTION=courses

# Modèle d'embeddings local (sentence-transformers, aucune clé requise)
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

APP_LOG_LEVEL=INFO
QUIZ_DEFAULT_QUESTIONS=5
MAX_HISTORY_TURNS=5

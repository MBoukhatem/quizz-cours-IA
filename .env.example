# ===== Ollama =====
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=mistral:7b
OLLAMA_TIMEOUT=120

# ===== ChromaDB =====
# CHROMA_HOST=chromadb is the docker-compose service name.
# Inside the docker network, the container listens on port 8000.
CHROMA_HOST=chromadb
CHROMA_PORT=8000

# ===== Backend =====
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
LOG_LEVEL=INFO
LOG_DIR=/data/logs

# ===== Embedding =====
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ===== Chunking =====
CHUNK_SIZE=500
CHUNK_OVERLAP=50
MIN_CHUNK_SIZE=100

# ===== Quiz / Planner =====
DEFAULT_DIFFICULTY=facile
QUESTIONS_FOR_ADAPTATION=5
TOP_K_CHUNKS=5

# ===== SQLite =====
DATABASE_PATH=/data/db/sessions.db

# ===== Frontend =====
# URL used by the Streamlit container to reach the FastAPI backend.
BACKEND_URL=http://backend:8000
